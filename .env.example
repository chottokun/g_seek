# LLM Configuration
LLM_PROVIDER=ollama
# "gemini", "openai", "azure_openai", "ollama", "placeholder_llm"
LLM_MODEL=qwen2.5:latest
# "gpt-4o", "gemini-1.5-pro", etc.

# OpenAI Specific Configuration
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_API_BASE_URL=http://localhost:8000/v1

# Gemini Specific Configuration
# GOOGLE_API_KEY=your_google_api_key

# Azure OpenAI Specific Configuration
# LLM_PROVIDER=azure_openai
# LLM_MODEL=deployment-name # For Azure, this is often the deployment name
# AZURE_OPENAI_API_KEY=your_azure_api_key
# AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# Ollama Specific Configuration
OLLAMA_BASE_URL=http://localhost:11434

# Search Configuration
SEARCH_API=duckduckgo
# "tavily", "searxng", "duckduckgo"
# TAVILY_API_KEY=your_tavily_key
# SEARXNG_BASE_URL=http://localhost:8080

# Research Loop Configuration
MAX_RESEARCH_LOOPS=3
MAX_SEARCH_RESULTS_PER_QUERY=3

# Output Configuration
OUTPUT_FILENAME=research_report.md

# Server Configuration
CHAINLIT_PORT=8000

# External Service Integration (Docker Network)
# If using docker-compose.searxng.yaml:
# SEARXNG_BASE_URL=http://searxng:8080
# If using docker-compose.ollama.yaml:
# OLLAMA_BASE_URL=http://ollama:11434

# Logging Configuration
LOG_LEVEL=INFO
# DEBUG, INFO, WARNING, ERROR
