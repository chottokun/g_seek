# LLM Configuration
LLM_PROVIDER=ollama
# "gemini", "openai", "azure_openai", "ollama", "placeholder_llm"
LLM_MODEL=qwen2.5:latest
# "gpt-4o", "gemini-1.5-pro", etc.
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192
FIXED_TEMPERATURE_MODELS="gpt-5,o1,o3"

# OpenAI Specific Configuration
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_API_BASE_URL=http://localhost:8000/v1

# Gemini Specific Configuration
# GOOGLE_API_KEY=your_google_api_key

# Azure OpenAI Specific Configuration
# AZURE_OPENAI_API_KEY=your_azure_api_key
# AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# Ollama Specific Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NUM_RETRIES=1
OLLAMA_RETRY_DELAY_SECONDS=2.0

# Search Configuration
SEARCH_API=duckduckgo
# "tavily", "searxng", "duckduckgo"
# TAVILY_API_KEY=your_tavily_key
# SEARXNG_BASE_URL=http://localhost:8080
SEARXNG_LANGUAGE=ja
SEARXNG_SAFESEARCH=1
SEARXNG_CATEGORIES=general

# Research Loop Configuration
MAX_RESEARCH_LOOPS=3
MAX_SEARCH_RESULTS_PER_QUERY=10
RESEARCH_PLAN_MIN_SECTIONS=3
RESEARCH_PLAN_MAX_SECTIONS=5

# Summarization Configuration
MAX_TEXT_LENGTH_PER_SOURCE_CHARS=4000
SUMMARIZATION_CHUNK_SIZE_CHARS=10000
SUMMARIZATION_CHUNK_OVERLAP_CHARS=500

# Optimization & Concurrency
MAX_CONCURRENT_CHUNKS=10
MAX_CONCURRENT_SECTIONS=2     # 同時に調査するセクション数
MAX_CONCURRENT_RETRIEVALS=20
LLM_RATE_LIMIT_RPM=60
LLM_RATE_LIMIT_TPM=40000
LLM_RETRY_BASE_DELAY=2.0

# Relevance Filtering
ENABLE_RELEVANCE_FILTERING=true
RELEVANCE_FILTER_MODE=snippet # 'snippet', 'full_content', 'disabled'
RELEVANCE_THRESHOLD=0.3
MAX_RELEVANT_RESULTS=5
ENABLE_QUERY_REGENERATION=true

# Skill Configuration
EVOLVE_SKILLS=true

# Output Configuration
OUTPUT_FILENAME=research_report.md
REPORT_DIR=temp_reports
DEFAULT_LANGUAGE=Japanese

# Other Configuration
LOG_LEVEL=INFO
INTERACTIVE_MODE=false
ENABLE_CACHING=true
CACHE_DIR=.cache
RETRIEVAL_TIMEOUT=15
USER_AGENT="DeepResearchBot/1.0"
MAX_FINAL_REPORT_CONTEXT_CHARS=102400

# Server Configuration
CHAINLIT_PORT=8000
